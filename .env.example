# Copy this file to `.env` and fill in your own values. `.env` is gitignored.
# All live features are OPTIONAL — the test suite and the notebooks run fully
# offline from the banked CSVs and never read these.

# The Odds API key (https://the-odds-api.com, free tier ~500 credits/month).
# Needed only for live odds refresh (src.odds.client / src.pipeline --live).
ODDS_API_KEY=

# Kicktipp login cookie value (the `login` cookie from a logged-in browser
# session). Needed only for live read-only scraping of your pool's pages.
KICKTIPP_SESSION=

# Your Kicktipp community (pool) slug — the path segment in the pool URL,
# e.g. https://www.kicktipp.co.uk/<your-pool-slug>/. Needed only for live scraping.
KICKTIPP_POOL=
